# Google OAuth credentials (from Google Cloud Console -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Preferred name. GOOGLE_API_CLIENT_SECRET is accepted as a fallback alias.
GOOGLE_CLIENT_SECRET=your-client-secret

# Redirect URI registered with Google Cloud. Defaults to localhost for dev.
# On Vercel set this to: https://<your-domain>/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Space-separated OAuth scopes. drive.file = only files this app creates/opens.
# Use https://www.googleapis.com/auth/drive for full read/write (requires verification for production).
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.file

# Secret used to encrypt the OAuth credentials cookie. Required on Vercel.
# Generate with: openssl rand -base64 48
AUTH_SECRET=replace-me-with-a-long-random-string

# Optional: local-only token file fallback for dev. Ignored on Vercel.
# GOOGLE_TOKEN_PATH=./google-token.json

# Kapso WhatsApp integration (https://app.kapso.ai)
# API key: dashboard -> API & webhooks -> create key.
KAPSO_API_KEY=your-kapso-api-key
# Numeric phone number ID (NOT the dial number). Dashboard -> Phone Numbers -> ID field.
KAPSO_PHONE_NUMBER_ID=your-kapso-phone-number-id
# Webhook secret shown when you register the endpoint in Kapso (used to verify X-Webhook-Signature).
# REQUIRED — without this the /api/kapso/webhook route 401s every request.
KAPSO_WEBHOOK_SECRET=your-kapso-webhook-secret
# Optional override; defaults to https://api.kapso.ai
# KAPSO_API_BASE=https://api.kapso.ai
